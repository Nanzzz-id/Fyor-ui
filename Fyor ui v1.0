local Icons = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/Icons/main/Main-v2.lua"))()
Icons.SetIconsType("lucide")

local function GetIcon(name)
    local ok, result = pcall(function() return Icons.Icon2(name) end)
    if ok and result then return result end
    return nil
end

local function ApplyIcon(img, iconData)
    if not iconData then return end
    local isStr = typeof(iconData) == "string"
    img.Image = isStr and iconData or iconData[1]
    if not isStr and iconData[2] then
        img.ImageRectSize = iconData[2].ImageRectSize
        img.ImageRectOffset = iconData[2].ImageRectPosition
    end
end

local WindUI = {
    CurrentTheme = {
        Accent      = Color3.fromRGB(0, 85, 185),
        AccentDark  = Color3.fromRGB(0, 55, 130),
        Background  = Color3.fromRGB(12, 12, 14),
        Secondary   = Color3.fromRGB(20, 20, 24),
        Tertiary    = Color3.fromRGB(28, 28, 34),
        Text        = Color3.fromRGB(235, 235, 240),
        SubText     = Color3.fromRGB(140, 140, 155),
        Border      = Color3.fromRGB(38, 38, 46),
        BorderLight = Color3.fromRGB(55, 55, 68),
    },
    CurrentFont = Enum.Font.GothamMedium,
    ScreenGui   = nil,
    NotifyGui   = nil,
    Closed      = false,
    Connections = {}
}

local function Tween(obj, info, goal)
    local t = TweenService:Create(obj,
        TweenInfo.new(info.Time or 0.3, info.Style or Enum.EasingStyle.Quart, info.Dir or Enum.EasingDirection.Out),
        goal)
    t:Play(); return t
end

function WindUI:ApplyThemeAccent(newAccent, newAccentDark)
    self.CurrentTheme.Accent = newAccent
    self.CurrentTheme.AccentDark = newAccentDark or Color3.fromRGB(
        math.floor(newAccent.R * 255 * 0.65),
        math.floor(newAccent.G * 255 * 0.65),
        math.floor(newAccent.B * 255 * 0.65)
    )
    if not self.ScreenGui then return end
    local function Walk(inst)
        for _, child in ipairs(inst:GetDescendants()) do
            if child:IsA("UIStroke") then
                local c = child.Color
                if math.abs(c.R - self.CurrentTheme.Border.R) < 0.01 and
                   math.abs(c.G - self.CurrentTheme.Border.G) < 0.01 and
                   math.abs(c.B - self.CurrentTheme.Border.B) < 0.01 then
                elseif c ~= Color3.fromRGB(0,0,0) and c ~= Color3.fromRGB(255,255,255) then
                    child.Color = newAccent
                end
            end
        end
    end

    local function UpdateAccentColor(inst)
        for _, child in ipairs(inst:GetDescendants()) do
            if child:IsA("Frame") or child:IsA("TextButton") or child:IsA("ImageLabel") or child:IsA("TextLabel") then
                local ok, bc = pcall(function() return child.BackgroundColor3 end)
                if ok then
                    local old = self.CurrentTheme.Accent
                    if math.abs(bc.R - old.R) < 0.02 and math.abs(bc.G - old.G) < 0.02 and math.abs(bc.B - old.B) < 0.02 then
                        child.BackgroundColor3 = newAccent
                    end
                end
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    local tc = child.TextColor3
                    local old = self.CurrentTheme.Accent
                    if math.abs(tc.R - old.R) < 0.02 and math.abs(tc.G - old.G) < 0.02 and math.abs(tc.B - old.B) < 0.02 then
                        child.TextColor3 = newAccent
                    end
                end
                if child:IsA("ImageLabel") then
                    local ic = child.ImageColor3
                    local old = self.CurrentTheme.Accent
                    if math.abs(ic.R - old.R) < 0.02 and math.abs(ic.G - old.G) < 0.02 and math.abs(ic.B - old.B) < 0.02 then
                        child.ImageColor3 = newAccent
                    end
                end
            end
            if child:IsA("UIStroke") then
                local sc = child.Color
                local old = self.CurrentTheme.Accent
                if math.abs(sc.R - old.R) < 0.02 and math.abs(sc.G - old.G) < 0.02 and math.abs(sc.B - old.B) < 0.02 then
                    child.Color = newAccent
                end
            end
            if child:IsA("ScrollingFrame") then
                local sc = child.ScrollBarImageColor3
                local old = self.CurrentTheme.Accent
                if math.abs(sc.R - old.R) < 0.02 and math.abs(sc.G - old.G) < 0.02 and math.abs(sc.B - old.B) < 0.02 then
                    child.ScrollBarImageColor3 = newAccent
                end
            end
        end
    end

    UpdateAccentColor(self.ScreenGui)
    self.CurrentTheme.Accent = newAccent
    if self.NotifyGui then
        UpdateAccentColor(self.NotifyGui)
    end
end

function WindUI:Notify(title, text, duration)
    if not self.NotifyGui then
        self.NotifyGui = Instance.new("ScreenGui", CoreGui)
        self.NotifyGui.Name = "WindUI_Notifications"
        local holder = Instance.new("Frame", self.NotifyGui)
        holder.Name = "Holder"
        holder.Size = UDim2.new(0, 310, 1, 0)
        holder.Position = UDim2.new(1, -320, 0, 0)
        holder.BackgroundTransparency = 1
        local layout = Instance.new("UIListLayout", holder)
        layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        layout.Padding = UDim.new(0, 8)
        local pad = Instance.new("UIPadding", holder)
        pad.PaddingBottom = UDim.new(0, 28)
    end

    local nFrame = Instance.new("Frame", self.NotifyGui.Holder)
    nFrame.Size = UDim2.new(1, 0, 0, 78)
    nFrame.BackgroundColor3 = self.CurrentTheme.Secondary
    nFrame.BackgroundTransparency = 1
    nFrame.ClipsDescendants = false
    Instance.new("UICorner", nFrame).CornerRadius = UDim.new(0, 18)

    local nStroke = Instance.new("UIStroke", nFrame)
    nStroke.Color = self.CurrentTheme.BorderLight
    nStroke.Transparency = 1
    nStroke.Thickness = 1

    local accentBar = Instance.new("Frame", nFrame)
    accentBar.Size = UDim2.new(0, 3, 0, 36)
    accentBar.Position = UDim2.new(0, 14, 0, 21)
    accentBar.BackgroundColor3 = self.CurrentTheme.Accent
    accentBar.BackgroundTransparency = 1
    Instance.new("UICorner", accentBar).CornerRadius = UDim.new(1, 0)

    local topGlow = Instance.new("Frame", nFrame)
    topGlow.Size = UDim2.new(1, 0, 0, 1)
    topGlow.Position = UDim2.new(0, 0, 0, 0)
    topGlow.BackgroundColor3 = self.CurrentTheme.Accent
    topGlow.BackgroundTransparency = 1
    Instance.new("UICorner", topGlow).CornerRadius = UDim.new(0, 18)

    local tLbl = Instance.new("TextLabel", nFrame)
    tLbl.Text = title:upper()
    tLbl.Size = UDim2.new(1, -45, 0, 18)
    tLbl.Position = UDim2.new(0, 28, 0, 16)
    tLbl.Font = Enum.Font.GothamBold
    tLbl.TextColor3 = self.CurrentTheme.Text
    tLbl.TextSize = 11
    tLbl.BackgroundTransparency = 1
    tLbl.TextXAlignment = Enum.TextXAlignment.Left
    tLbl.TextTransparency = 1

    local dot = Instance.new("Frame", nFrame)
    dot.Size = UDim2.new(0, 3, 0, 3)
    dot.Position = UDim2.new(0, 28, 0, 38)
    dot.BackgroundColor3 = self.CurrentTheme.Accent
    dot.BackgroundTransparency = 1
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local sLbl = Instance.new("TextLabel", nFrame)
    sLbl.Text = text
    sLbl.Size = UDim2.new(1, -42, 0, 28)
    sLbl.Position = UDim2.new(0, 36, 0, 44)
    sLbl.Font = Enum.Font.GothamMedium
    sLbl.TextColor3 = self.CurrentTheme.SubText
    sLbl.TextSize = 11
    sLbl.BackgroundTransparency = 1
    sLbl.TextXAlignment = Enum.TextXAlignment.Left
    sLbl.TextYAlignment = Enum.TextYAlignment.Top
    sLbl.TextWrapped = true
    sLbl.TextTransparency = 1

    local progTrack = Instance.new("Frame", nFrame)
    progTrack.Size = UDim2.new(1, -28, 0, 2)
    progTrack.Position = UDim2.new(0, 14, 1, -10)
    progTrack.BackgroundColor3 = self.CurrentTheme.Border
    progTrack.BackgroundTransparency = 1
    Instance.new("UICorner", progTrack).CornerRadius = UDim.new(1, 0)

    local progFill = Instance.new("Frame", progTrack)
    progFill.Size = UDim2.new(1, 0, 1, 0)
    progFill.BackgroundColor3 = self.CurrentTheme.Accent
    progFill.BackgroundTransparency = 1
    Instance.new("UICorner", progFill).CornerRadius = UDim.new(1, 0)

    nFrame.Position = UDim2.new(0, 0, 0, 80)
    Tween(nFrame,    {Time = 0.45, Style = Enum.EasingStyle.Quart}, {Position = UDim2.new(0,0,0,0), BackgroundTransparency = 0})
    Tween(nStroke,   {Time = 0.45}, {Transparency = 0.4})
    Tween(accentBar, {Time = 0.45}, {BackgroundTransparency = 0})
    Tween(topGlow,   {Time = 0.45}, {BackgroundTransparency = 0.7})
    Tween(tLbl,      {Time = 0.45}, {TextTransparency = 0})
    Tween(sLbl,      {Time = 0.45}, {TextTransparency = 0})
    Tween(dot,       {Time = 0.45}, {BackgroundTransparency = 0})
    Tween(progTrack, {Time = 0.45}, {BackgroundTransparency = 0.6})
    Tween(progFill,  {Time = 0.45}, {BackgroundTransparency = 0})

    task.delay(0.45, function()
        Tween(progFill, {Time = (duration or 4) - 0.45, Style = Enum.EasingStyle.Linear}, {Size = UDim2.new(0,0,1,0)})
    end)

    task.delay(duration or 4, function()
        Tween(nFrame,    {Time = 0.4, Style = Enum.EasingStyle.Back, Dir = Enum.EasingDirection.In}, {Position = UDim2.new(0,0,0,-100), BackgroundTransparency = 1})
        Tween(nStroke,   {Time = 0.3}, {Transparency = 1})
        Tween(tLbl,      {Time = 0.3}, {TextTransparency = 1})
        Tween(sLbl,      {Time = 0.3}, {TextTransparency = 1})
        Tween(accentBar, {Time = 0.3}, {BackgroundTransparency = 1})
        task.wait(0.45)
        nFrame:Destroy()
    end)
end

local function MakeDraggable(dragPart, mainFrame)
    local dragging, dragStart, startPos
    dragPart.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = mainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

