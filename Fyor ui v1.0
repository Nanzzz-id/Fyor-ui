    stroke.Color = WindUI.CurrentTheme.Border
    stroke.Thickness = 1
    local tl = Instance.new("TextLabel", card)
    tl.Size = UDim2.new(1, -10, 0, 18)
    tl.Position = UDim2.new(0, 12, 0, 8)
    tl.Text = title:upper()
    tl.BackgroundTransparency = 1
    tl.TextColor3 = WindUI.CurrentTheme.SubText
    tl.Font = Enum.Font.Gotham
    tl.TextSize = 9
    tl.TextXAlignment = Enum.TextXAlignment.Left
    local vl = Instance.new("TextLabel", card)
    vl.Size = UDim2.new(1, -10, 0, 20)
    vl.Position = UDim2.new(0, 12, 0, 28)
    vl.Text = value
    vl.BackgroundTransparency = 1
    vl.TextColor3 = WindUI.CurrentTheme.Accent
    vl.Font = Enum.Font.GothamBold
    vl.TextSize = 12
    vl.TextXAlignment = Enum.TextXAlignment.Left
end

