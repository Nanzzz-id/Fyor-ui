local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Nanzzz-id/Fyor-ui/refs/heads/main/Fyor%20ui%20v1.0"))()
local Window = WindUI:CreateWindow("Fyor Hub")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local camera = Workspace.CurrentCamera
local localPlayer = Players.LocalPlayer
local FlickEnabled = false
local FlickStrength = 0.12
local WallCheck = true
local FlickFOV = 80
local FlickCooldown = 0.13
local MaxDistance = 350
local LastFlick = 0
local TeamCheck = false
local AimbotEnabled = false
local AimbotFOV = 120
local AimbotSmooth = 0.25
local AimPart = "Head"
local ShowFOVCircle = true
local FOVColor = Color3.fromRGB(255, 255, 255)
local FOVThickness = 2
local FOVRadius = 120
local HighlightESP = false
local TracerESP = false
local TracerThickness = 2
local TracerColor = Color3.fromRGB(255, 0, 0)
local HitboxEnabled = false
local HitboxSize = 6
local HitboxTransparency = 0.7
local R6_PARTS = {"Head", "HumanoidRootPart", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}
local R15_PARTS = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "LeftUpperArm", "RightUpperArm", "LeftUpperLeg", "RightUpperLeg", "LeftLowerArm", "RightLowerArm", "LeftLowerLeg", "RightLowerLeg", "LeftHand", "RightHand", "LeftFoot", "RightFoot"}
local originalSizes = {}

-- Forward declare isEnemy agar bisa dipakai sebelum definisinya
local isEnemy

local function expandHitbox(char)
    if not char then return end
    local parts = {}
    for _, name in R6_PARTS do
        local p = char:FindFirstChild(name)
        if p and p:IsA("BasePart") then parts[#parts+1] = p end
    end
    for _, name in R15_PARTS do
        local p = char:FindFirstChild(name)
        if p and p:IsA("BasePart") and not table.find(parts, p) then parts[#parts+1] = p end
    end
    for _, part in parts do
        pcall(function()
            if not originalSizes[part] then
                originalSizes[part] = part.Size
            end
            -- Gunakan CustomPhysicalProperties agar size tidak di-override server
            part.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
            part.LocalTransparencyModifier = HitboxTransparency
            part.CanCollide = false
        end)
    end
end
local function resetHitbox(char)
    if not char then return end
    for _, part in char:GetDescendants() do
        if part:IsA("BasePart") then
            pcall(function()
                if originalSizes[part] then
                    part.Size = originalSizes[part]
                    originalSizes[part] = nil
                end
                part.LocalTransparencyModifier = 0
                part.CanCollide = true
            end)
        end
    end
end

-- Gunakan Heartbeat agar hitbox diperbarui setiap frame (tidak bisa di-override server)
RunService.Heartbeat:Connect(function()
    if not HitboxEnabled then return end
    for _, plr in Players:GetPlayers() do
        if plr ~= localPlayer and plr.Character then
            if isEnemy(plr) then
                expandHitbox(plr.Character)
            end
        end
    end
end)

-- Reset hitbox saat disabled
local prevHitboxEnabled = false
RunService.Heartbeat:Connect(function()
    if prevHitboxEnabled and not HitboxEnabled then
        for _, plr in Players:GetPlayers() do
            if plr ~= localPlayer and plr.Character then
                resetHitbox(plr.Character)
            end
        end
    end
    prevHitboxEnabled = HitboxEnabled
end)
local FOVCircle = Drawing.new("Circle")
FOVCircle.Filled = false
FOVCircle.Thickness = FOVThickness
FOVCircle.Color = FOVColor
FOVCircle.NumSides = 512
FOVCircle.Radius = FOVRadius
FOVCircle.Visible = false
FOVCircle.ZIndex = 999
local FOVCircleOutline = Drawing.new("Circle")
FOVCircleOutline.Filled = false
FOVCircleOutline.Thickness = FOVThickness + 2
FOVCircleOutline.Color = Color3.fromRGB(0, 0, 0)
FOVCircleOutline.NumSides = 512
FOVCircleOutline.Radius = FOVRadius
FOVCircleOutline.Visible = false
FOVCircleOutline.ZIndex = 998
local function SetFOVCircle(cx, cy, radius, visible)
    FOVCircle.Position = Vector2.new(cx, cy)
    FOVCircle.Radius = radius
    FOVCircle.Color = FOVColor
    FOVCircle.Thickness = FOVThickness
    FOVCircle.Visible = visible
    FOVCircleOutline.Position = Vector2.new(cx, cy)
    FOVCircleOutline.Radius = radius + 1
    FOVCircleOutline.Thickness = FOVThickness + 2
    FOVCircleOutline.Visible = visible
end
local Tracers = {}
local function isVisible(targetPart)
    if not WallCheck then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {localPlayer.Character or Workspace}
    local result = Workspace:Raycast(camera.CFrame.Position, targetPart.Position - camera.CFrame.Position, params)
    return not result or result.Instance:IsDescendantOf(targetPart.Parent)
end
isEnemy = function(plr)
    if not TeamCheck then return true end
    local ok, result = pcall(function()
        if plr.Team and localPlayer.Team then
            if plr.Team ~= localPlayer.Team then return true end
            return false
        end
        local plrStats = plr:FindFirstChild("leaderstats")
        local localStats = localPlayer:FindFirstChild("leaderstats")
        if plrStats and localStats then
            local t1 = plrStats:FindFirstChild("Team") or plrStats:FindFirstChild("team") or plrStats:FindFirstChild("Guild") or plrStats:FindFirstChild("Clan")
            local t2 = localStats:FindFirstChild("Team") or localStats:FindFirstChild("team") or localStats:FindFirstChild("Guild") or localStats:FindFirstChild("Clan")
            if t1 and t2 then
                return t1.Value ~= t2.Value
            end
        end
        local a1 = plr.Character and plr.Character:GetAttribute("Team") or plr:GetAttribute("Team")
        local a2 = localPlayer.Character and localPlayer.Character:GetAttribute("Team") or localPlayer:GetAttribute("Team")
        if a1 ~= nil and a2 ~= nil then
            return a1 ~= a2
        end
        local tf1 = plr.Character and (plr.Character:FindFirstChild("TeamFolder") or plr.Character:FindFirstChild("TeamValue"))
        local tf2 = localPlayer.Character and (localPlayer.Character:FindFirstChild("TeamFolder") or localPlayer.Character:FindFirstChild("TeamValue"))
        if tf1 and tf2 then
            return tf1.Value ~= tf2.Value
        end
        return true
    end)
    if ok then return result end
    return true
end
local function getTargetPart(char)
    if not char then return nil end
    if AimPart == "Head" then
        return char:FindFirstChild("Head")
    elseif AimPart == "HumanoidRootPart" then
        return char:FindFirstChild("HumanoidRootPart")
    elseif AimPart == "Torso" then
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("LowerTorso") or char:FindFirstChild("HumanoidRootPart")
    end
    return char:FindFirstChild("Head")
end
local function updateESP()
    for _, plr in Players:GetPlayers() do
        if plr == localPlayer then continue end
        local char = plr.Character
        if not char then continue end
        if not isEnemy(plr) then
            local hl = char:FindFirstChild("Highlight_Zenith")
            if hl then hl:Destroy() end
            if Tracers[plr] then Tracers[plr].Visible = false end
            continue
        end
        if HighlightESP then
            if not char:FindFirstChild("Highlight_Zenith") then
                local hl = Instance.new("Highlight", char)
                hl.Name = "Highlight_Zenith"
                hl.FillTransparency = 1
                hl.OutlineColor = Color3.fromRGB(255, 0, 0)
                hl.OutlineTransparency = 0
            end
        else
            local hl = char:FindFirstChild("Highlight_Zenith")
            if hl then hl:Destroy() end
        end
        if TracerESP then
            if not Tracers[plr] then
                local line = Drawing.new("Line")
                line.Thickness = TracerThickness
                line.Color = TracerColor
                line.Transparency = 1
                Tracers[plr] = line
            end
            local part = getTargetPart(char)
            if part and isVisible(part) then
                local pos, onScreen = camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    Tracers[plr].From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y)
                    Tracers[plr].To = Vector2.new(pos.X, pos.Y)
                    Tracers[plr].Visible = true
                else
                    Tracers[plr].Visible = false
                end
            else
                Tracers[plr].Visible = false
            end
        else
            if Tracers[plr] then Tracers[plr].Visible = false end
        end
    end
end
Players.PlayerRemoving:Connect(function(plr)
    if Tracers[plr] then Tracers[plr]:Remove() Tracers[plr] = nil end
end)
local function getClosestFlick()
    local closest, shortest = nil, FlickFOV
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    for _, plr in Players:GetPlayers() do
        if plr == localPlayer then continue end
        if not isEnemy(plr) then continue end
        local char = plr.Character
        local part = getTargetPart(char)
        if part and (part.Position - camera.CFrame.Position).Magnitude <= MaxDistance then
            local pos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen and isVisible(part) then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = part
                end
            end
        end
    end
    return closest
end
local function getAimbotTarget()
    local closest, shortest = nil, AimbotFOV
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    for _, plr in Players:GetPlayers() do
        if plr == localPlayer then continue end
        if not isEnemy(plr) then continue end
        local char = plr.Character
        local part = getTargetPart(char)
        if part then
            local pos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen and (not WallCheck or isVisible(part)) then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = part
                end
            end
        end
    end
    return closest
end
RunService.RenderStepped:Connect(function()
    if AimbotEnabled then
        local target = getAimbotTarget()
        if target then
            local dir = (target.Position - camera.CFrame.Position).Unit
            camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + dir), AimbotSmooth)
        end
    end
    if FlickEnabled and tick() - LastFlick >= FlickCooldown then
        local target = getClosestFlick()
        if target then
            local dir = (target.Position - camera.CFrame.Position).Unit
            camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + dir), FlickStrength)
            LastFlick = tick()
        end
    end
    local radius = FOVRadius
    local show = ShowFOVCircle and (AimbotEnabled or FlickEnabled)
    local cx = camera.ViewportSize.X / 2
    local cy = camera.ViewportSize.Y / 2
    SetFOVCircle(cx, cy, radius, show)
    updateESP()
end)

