local function MakeSettingsCard(parent, height)
    local card = Instance.new("Frame", parent)
    card.Size = UDim2.new(0.95, 0, 0, height or 52)
    card.BackgroundColor3 = WindUI.CurrentTheme.Secondary
    card.BackgroundTransparency = 0.15
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 16)
    local stroke = Instance.new("UIStroke", card)
    stroke.Color = WindUI.CurrentTheme.Border
    stroke.Thickness = 1
    return card
end

local function MakeSectionHeader(parent, icon, title, subtitle)
    local hdr = Instance.new("Frame", parent)
    hdr.Size = UDim2.new(0.95, 0, 0, 48)
    hdr.BackgroundTransparency = 1

    local iconBox = Instance.new("Frame", hdr)
    iconBox.Size = UDim2.new(0, 32, 0, 32)
    iconBox.Position = UDim2.new(0, 0, 0.5, -16)
    iconBox.BackgroundColor3 = WindUI.CurrentTheme.Accent
    iconBox.BackgroundTransparency = 0.82
    Instance.new("UICorner", iconBox).CornerRadius = UDim.new(0, 10)
    local iconStroke = Instance.new("UIStroke", iconBox)
    iconStroke.Color = WindUI.CurrentTheme.Accent
    iconStroke.Thickness = 1
    iconStroke.Transparency = 0.5

    local ico = Instance.new("ImageLabel", iconBox)
    ico.Size = UDim2.new(0, 15, 0, 15)
    ico.Position = UDim2.new(0.5, -7.5, 0.5, -7.5)
    ico.BackgroundTransparency = 1
    ico.ImageColor3 = WindUI.CurrentTheme.Accent
    ico.ScaleType = Enum.ScaleType.Fit
    task.spawn(function() ApplyIcon(ico, GetIcon(icon)) end)

    local titleLbl = Instance.new("TextLabel", hdr)
    titleLbl.Size = UDim2.new(1, -44, 0, 16)
    titleLbl.Position = UDim2.new(0, 44, 0, 8)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextColor3 = WindUI.CurrentTheme.Text
    titleLbl.TextSize = 12
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    local subLbl = Instance.new("TextLabel", hdr)
    subLbl.Size = UDim2.new(1, -44, 0, 14)
    subLbl.Position = UDim2.new(0, 44, 0, 26)
    subLbl.BackgroundTransparency = 1
    subLbl.Text = subtitle
    subLbl.Font = Enum.Font.Gotham
    subLbl.TextColor3 = WindUI.CurrentTheme.SubText
    subLbl.TextSize = 10
    subLbl.TextXAlignment = Enum.TextXAlignment.Left
end

