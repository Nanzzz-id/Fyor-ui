    freeBadge.Position = UDim2.new(1, -50, 0.5, -8.5)
    freeBadge.BackgroundColor3 = self.CurrentTheme.Accent
    freeBadge.BackgroundTransparency = 0.82
    Instance.new("UICorner", freeBadge).CornerRadius = UDim.new(1, 0)
    local freeBadgeStroke = Instance.new("UIStroke", freeBadge)
