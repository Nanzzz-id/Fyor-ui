scaleSub.Font = Enum.Font.Gotham
scaleSub.TextColor3 = WindUI.CurrentTheme.SubText
scaleSub.TextSize = 9
scaleSub.TextXAlignment = Enum.TextXAlignment.Left

local scaleOptions = {"Small", "Normal", "Large"}
local scaleIdx = 2
local scaleValueLbl = Instance.new("TextLabel", scaleCard)
scaleValueLbl.Size = UDim2.new(0, 48, 0, 22)
scaleValueLbl.Position = UDim2.new(1, -140, 0.5, -11)
scaleValueLbl.BackgroundTransparency = 1
scaleValueLbl.Text = scaleOptions[scaleIdx]
scaleValueLbl.Font = Enum.Font.GothamBold
scaleValueLbl.TextColor3 = WindUI.CurrentTheme.Accent
scaleValueLbl.TextSize = 11
scaleValueLbl.TextXAlignment = Enum.TextXAlignment.Center

local scalePrev = Instance.new("TextButton", scaleCard)
scalePrev.Size = UDim2.new(0, 28, 0, 28)
scalePrev.Position = UDim2.new(1, -112, 0.5, -14)
scalePrev.BackgroundColor3 = WindUI.CurrentTheme.Tertiary
scalePrev.Text = "‹"
scalePrev.Font = Enum.Font.GothamBold
scalePrev.TextColor3 = WindUI.CurrentTheme.SubText
scalePrev.TextSize = 14
Instance.new("UICorner", scalePrev).CornerRadius = UDim.new(0, 8)

local scaleNext = Instance.new("TextButton", scaleCard)
scaleNext.Size = UDim2.new(0, 28, 0, 28)
scaleNext.Position = UDim2.new(1, -56, 0.5, -14)
scaleNext.BackgroundColor3 = WindUI.CurrentTheme.Tertiary
scaleNext.Text = "›"
scaleNext.Font = Enum.Font.GothamBold
scaleNext.TextColor3 = WindUI.CurrentTheme.SubText
scaleNext.TextSize = 14
Instance.new("UICorner", scaleNext).CornerRadius = UDim.new(0, 8)

local function ApplyScale()
    local v = scaleOptions[scaleIdx]
    scaleValueLbl.Text = v
    local tb = WindUI.ScreenGui and WindUI.ScreenGui:FindFirstChild("UI_Container")
    local scales = {Small = UDim2.new(0,440,0,330), Normal = UDim2.new(0,540,0,390), Large = UDim2.new(0,660,0,460)}
    if tb and scales[v] then tb.Size = scales[v] end
    WindUI:Notify("Settings", "UI Scale set to " .. v, 2)
end
scalePrev.MouseButton1Click:Connect(function()
    scaleIdx = scaleIdx > 1 and scaleIdx - 1 or #scaleOptions
    ApplyScale()
end)
scaleNext.MouseButton1Click:Connect(function()
    scaleIdx = scaleIdx < #scaleOptions and scaleIdx + 1 or 1
    ApplyScale()
end)

