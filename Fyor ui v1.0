task.spawn(function() ApplyIcon(kbIco, GetIcon("keyboard")) end)

local kbLbl = Instance.new("TextLabel", keybindFrame)
kbLbl.Size = UDim2.new(0.55, 0, 1, 0)
kbLbl.Position = UDim2.new(0, 34, 0, 0)
kbLbl.BackgroundTransparency = 1
kbLbl.Text = "Toggle Key"
kbLbl.Font = WindUI.CurrentFont
kbLbl.TextColor3 = WindUI.CurrentTheme.Text
kbLbl.TextSize = 12
kbLbl.TextXAlignment = Enum.TextXAlignment.Left

local kbBtn = Instance.new("TextButton", keybindFrame)
kbBtn.Size = UDim2.new(0, 96, 0, 28)
kbBtn.Position = UDim2.new(1, -108, 0.5, -14)
kbBtn.BackgroundColor3 = WindUI.CurrentTheme.Accent
kbBtn.BackgroundTransparency = 0.8
kbBtn.Text = tostring(currentKey):gsub("Enum.KeyCode.", "")
kbBtn.Font = Enum.Font.GothamBold
kbBtn.TextColor3 = WindUI.CurrentTheme.Accent
kbBtn.TextSize = 10
Instance.new("UICorner", kbBtn).CornerRadius = UDim.new(0, 10)
local kbBtnStroke = Instance.new("UIStroke", kbBtn)
kbBtnStroke.Color = WindUI.CurrentTheme.Accent
kbBtnStroke.Thickness = 1
kbBtnStroke.Transparency = 0.45

kbBtn.MouseEnter:Connect(function() Tween(kbBtn, {Time=0.15}, {BackgroundTransparency=0.55}) end)
kbBtn.MouseLeave:Connect(function() Tween(kbBtn, {Time=0.15}, {BackgroundTransparency=0.8}) end)

kbBtn.MouseButton1Click:Connect(function()
    if bindingActive then return end
    bindingActive = true
    kbBtn.Text = "· · ·"
    kbBtn.TextColor3 = WindUI.CurrentTheme.SubText
    Tween(kbBtn, {Time=0.15}, {BackgroundTransparency=0.6})
    local conn
    conn = UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.UserInputType == Enum.UserInputType.Keyboard then
            currentKey = input.KeyCode
            kbBtn.Text = tostring(currentKey):gsub("Enum.KeyCode.", "")
            kbBtn.TextColor3 = WindUI.CurrentTheme.Accent
            Tween(kbBtn, {Time=0.15}, {BackgroundTransparency=0.8})
            bindingActive = false
            conn:Disconnect()
            WindUI:Notify("Keybind", "Toggle key set to: " .. tostring(currentKey):gsub("Enum.KeyCode.", ""), 2)
        end
    end)
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if not bindingActive and input.KeyCode == currentKey then
        WindUI.Closed = not WindUI.Closed
        local c2 = WindUI.ScreenGui:FindFirstChild("UI_Container")
        local m2 = c2 and c2:FindFirstChild("MainFrame")
        local d2 = c2 and c2:FindFirstChild("ExternalDrag")
        if c2 and m2 then
            if WindUI.Closed then
                Tween(m2, {Time=0.3, Style=Enum.EasingStyle.Quart, Dir=Enum.EasingDirection.In}, {GroupTransparency=1, Size=UDim2.new(0,540,0,0)})
                if d2 then Tween(d2, {Time=0.2}, {BackgroundTransparency=1}) end
                task.delay(0.32, function() c2.Visible = false end)
            else
                c2.Visible = true
                m2.Size = UDim2.new(0,540,0,0)
                m2.GroupTransparency = 1
                Tween(m2, {Time=0.45, Style=Enum.EasingStyle.Back}, {Size=UDim2.new(1,0,1,0), GroupTransparency=0})
                if d2 then Tween(d2, {Time=0.3}, {BackgroundTransparency=0.6}) end
            end
        end
    end
end)

