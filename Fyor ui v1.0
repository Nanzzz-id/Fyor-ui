sfSubLbl.TextSize = 9
sfSubLbl.TextXAlignment = Enum.TextXAlignment.Left

local saveConfirmed = false
local saveConfirmTimer = nil

local saveBtn = Instance.new("TextButton", saveFrame)
saveBtn.Size = UDim2.new(0, 80, 0, 28)
saveBtn.Position = UDim2.new(1, -94, 0.5, -14)
saveBtn.BackgroundColor3 = WindUI.CurrentTheme.Accent
saveBtn.BackgroundTransparency = 0.78
saveBtn.Text = "Save"
saveBtn.Font = Enum.Font.GothamBold
saveBtn.TextColor3 = WindUI.CurrentTheme.Accent
saveBtn.TextSize = 10
Instance.new("UICorner", saveBtn).CornerRadius = UDim.new(0, 10)
local saveBtnStroke = Instance.new("UIStroke", saveBtn)
saveBtnStroke.Color = WindUI.CurrentTheme.Accent
saveBtnStroke.Thickness = 1
saveBtnStroke.Transparency = 0.5

saveBtn.MouseEnter:Connect(function() Tween(saveBtn, {Time=0.15}, {BackgroundTransparency=0.5}) end)
saveBtn.MouseLeave:Connect(function() Tween(saveBtn, {Time=0.15}, {BackgroundTransparency=0.78}) end)

saveBtn.MouseButton1Click:Connect(function()
    if not saveConfirmed then
        saveConfirmed = true
        saveBtn.Text = "Confirm?"
        saveBtn.TextColor3 = Color3.fromRGB(255, 210, 60)
        Tween(saveBtn, {Time=0.15}, {BackgroundTransparency=0.5})
        if saveConfirmTimer then saveConfirmTimer:Cancel() end
        saveConfirmTimer = task.delay(2.5, function()
            saveConfirmed = false
            saveBtn.Text = "Save"
            saveBtn.TextColor3 = WindUI.CurrentTheme.Accent
            Tween(saveBtn, {Time=0.2}, {BackgroundTransparency=0.78})
        end)
    else
        saveConfirmed = false
        saveBtn.Text = "Saved."
        saveBtn.TextColor3 = Color3.fromRGB(80, 210, 130)
        Tween(saveBtn, {Time=0.15}, {BackgroundTransparency=0.6})
        WindUI:Notify("Settings", "Configuration saved successfully.", 3)
        task.delay(2, function()
            saveBtn.Text = "Save"
            saveBtn.TextColor3 = WindUI.CurrentTheme.Accent
            Tween(saveBtn, {Time=0.2}, {BackgroundTransparency=0.78})
        end)
    end
end)

