resetBtn.MouseLeave:Connect(function() Tween(resetBtn, {Time=0.15}, {BackgroundTransparency=0.78}) end)
resetBtn.MouseButton1Click:Connect(function()
    FlickEnabled  = false
    AimbotEnabled = false
    ShowFOVCircle = true
    WallCheck     = true
    HighlightESP  = false
    TracerESP     = false
    HitboxEnabled = false
    FlickFOV      = 80
    FlickStrength = 0.12
    FlickCooldown = 0.13
    AimbotFOV     = 120
    AimbotSmooth  = 0.25
    HitboxSize    = 6
    WindUI:Notify("Settings", "All settings have been reset to default.", 3)
end)

